# ==========================================
# SQL API Gateway - Environment Configuration
# ==========================================

# --- 1. Global Security ---
# Master API Key required for all requests (send via 'X-API-Key' header or '?api_key=' query param)
API_KEY=your_super_secret_api_key_here

# (Optional) IP Whitelisting: Comma-separated list of allowed IPs. 
# Leave blank to allow all IPs.
# ALLOWED_IPS=127.0.0.1, 192.168.1.5, 203.0.113.50

# (Optional) CORS Allow Origin: Restrict which browser domains can call this API.
# Leave as * to allow all domains, or set to specific frontend URLs.
# ALLOWED_ORIGIN=https://myfrontend.com


# --- 2. Database Connections ---
# You can define as many databases as you want.
# Format: DB_URL_{NAME} = {sqlalchemy_connection_string}
# Replace '{NAME}' with the identifier used in your API URL (e.g. /api/{NAME}/query)

# Example: MySQL
# Format: mysql+pymysql://<user>:<password>@<host>:<port>/<dbname>
DB_URL_MAIN=mysql+pymysql://my_db_user:my_db_pass@127.0.0.1:3306/my_database

# Example: SQLite
DB_URL_TEST=sqlite:///./test.db

# Example: PostgreSQL
# DB_URL_PG=postgresql://pg_user:pg_pass@localhost:5432/pg_db


# --- 3. Database Operation Modes (Optional) ---
# Format: DB_MODE_{NAME} = READWRITE (default) | READONLY
# If set to READONLY, all INSERT, UPDATE, DELETE, DROP, and ALTER queries will be blocked.

# Protect 'MAIN' database from writes
DB_MODE_MAIN=READONLY

# Allow full access to 'TEST' database
DB_MODE_TEST=READWRITE
